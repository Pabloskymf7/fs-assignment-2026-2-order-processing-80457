@page "{productId:long}"
@model SportsStore.Pages.ProductDetailsModel

@if (Model.Product == null)
{
    <p class="alert alert-danger">Product not found.</p>
}
else
{
    <div class="card">
        <div class="card-body">
            <h2>@Model.Product.Name</h2>
            <p class="text-muted">@Model.Product.Category</p>
            <p>@Model.Product.Description</p>
            <h4 class="text-success">@Model.Product.Price.ToString("c")</h4>
            <form asp-page-handler="AddToCart" method="post">
                <input type="hidden" name="productId" value="@Model.Product.ProductID" />
                <input type="hidden" name="returnUrl" value="/ProductDetails/@Model.Product.ProductID" />
                <div class="form-group mb-3">
                    <label>Quantity</label>
                    <input type="number" name="quantity" value="1" min="1" max="10" class="form-control" style="width:80px" />
                </div>
                <button type="submit" class="btn btn-primary">Add to Cart</button>
                <a class="btn btn-secondary ms-2" href="/">Back to Products</a>
            </form>
        </div>
    </div>
}
