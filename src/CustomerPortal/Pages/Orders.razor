@page "/orders"
@using global::Shared.DTOs
@inject OrderApiService OrderApi

<h2>My Orders</h2>

@if (_loading)
{
    <p>Loading orders...</p>
}
else if (!_orders.Any())
{
    <p>No orders found.</p>
}
else
{
    <table style="width:100%; border-collapse:collapse;">
        <thead>
            <tr style="background:#f0f0f0;">
                <th style="padding:8px; text-align:left;">Order ID</th>
                <th style="padding:8px;">Date</th>
                <th style="padding:8px;">Total</th>
                <th style="padding:8px;">Status</th>
                <th style="padding:8px;">Tracking</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in _orders)
            {
                <tr style="border-bottom:1px solid #eee;">
                    <td style="padding:8px; font-size:12px;">
                        <a href="/track/@order.Id">@order.Id.ToString().Substring(0,8)...</a>
                    </td>
                    <td style="padding:8px; text-align:center;">@order.CreatedAt.ToShortDateString()</td>
                    <td style="padding:8px; text-align:center;">@order.TotalAmount</td>
                    <td style="padding:8px; text-align:center;">
                        <span style="padding:4px 8px; border-radius:4px; background:@GetStatusColor(order.Status); color:white;">
                            @order.Status
                        </span>
                    </td>
                    <td style="padding:8px; text-align:center;">@(order.TrackingReference ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<OrderDto> _orders = new();
    private bool _loading = true;
    private Guid _customerId = Guid.Parse("3fa85f64-5717-4562-b3fc-2c963f66afa6");

    protected override async Task OnInitializedAsync()
    {
        _orders = await OrderApi.GetCustomerOrdersAsync(_customerId);
        _loading = false;
    }

    private string GetStatusColor(string status) => status switch
    {
        "Completed" => "#4caf50",
        "PaymentFailed" or "InventoryFailed" or "Failed" => "#f44336",
        "ShippingCreated" => "#2196f3",
        "PaymentApproved" => "#8bc34a",
        _ => "#ff9800"
    };
}

