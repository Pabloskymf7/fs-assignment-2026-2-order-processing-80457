@page "/"
@inject CartService Cart
@inject NavigationManager Nav

<h2>SportsStore</h2>
<p>Welcome! Browse our products below.</p>

<div style="display:flex; flex-wrap:wrap; gap:20px; margin-top:20px;">
    @foreach (var product in _products)
    {
        <div style="border:1px solid #ccc; border-radius:8px; padding:16px; width:220px;">
            <h4>@product.Name</h4>
            <p style="color:gray;">@product.Description</p>
            <p><strong>€@product.Price</strong></p>
            <input type="number" min="1" max="10" @bind="product.SelectedQty"
                   style="width:60px; margin-right:8px;" />
            <button @onclick="() => AddToCart(product)">Add to Cart</button>
        </div>
    }
</div>

@if (_added)
{
    <p style="color:green; margin-top:10px;">Item added to cart!</p>
}

@code {
    private List<ProductViewModel> _products = new()
    {
        new(1, "Running Shoes", "Lightweight running shoes", 59.99m),
        new(2, "Sports T-Shirt", "Breathable fabric", 24.99m),
        new(3, "Water Bottle", "1L insulated bottle", 14.99m),
        new(4, "Yoga Mat", "Non-slip surface", 34.99m),
        new(5, "Resistance Bands", "Set of 3", 19.99m),
    };

    private bool _added = false;

    private void AddToCart(ProductViewModel p)
    {
        Cart.AddItem(new global::Shared.DTOs.CartItemDto
        {
            ProductId = p.Id,
            ProductName = p.Name,
            Quantity = p.SelectedQty,
            UnitPrice = p.Price
        });
        _added = true;
        StateHasChanged();
        Task.Delay(2000).ContinueWith(_ =>
        {
            _added = false;
            InvokeAsync(StateHasChanged);
        });
    }

    record ProductViewModel(int Id, string Name, string Description, decimal Price)
    {
        public int SelectedQty { get; set; } = 1;
    }
}

